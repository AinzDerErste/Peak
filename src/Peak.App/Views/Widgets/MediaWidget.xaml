<UserControl x:Class="Peak.App.Views.Widgets.MediaWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Peak.App.Views.Widgets"
             FontFamily="{StaticResource InterFont}">
    <Grid VerticalAlignment="Top">
        <!-- Media controls -->
        <StackPanel Visibility="{Binding HasMedia, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="56" Height="56" CornerRadius="10" Margin="0,0,10,0">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding AlbumArt}" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontSize="13"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding MediaArtist}" Foreground="#88FFFFFF" FontSize="11"
                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                        <Button Command="{Binding PreviousTrackCommand}" Style="{StaticResource IconButton}" Focusable="False">
                            <Path Data="{StaticResource IconBackward}" Fill="White" Stretch="Uniform" Width="11" Height="11" />
                        </Button>
                        <Button Command="{Binding PlayPauseCommand}" Style="{StaticResource IconButton}" Margin="3,0" Focusable="False">
                            <Path Data="{Binding PlayPauseIcon}" Fill="White" Stretch="Uniform" Width="12" Height="12" />
                        </Button>
                        <Button Command="{Binding NextTrackCommand}" Style="{StaticResource IconButton}" Focusable="False">
                            <Path Data="{StaticResource IconForward}" Fill="White" Stretch="Uniform" Width="11" Height="11" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <!-- Progress bar + time -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Track bar: background + fill via ScaleTransform -->
                <Border Height="3" CornerRadius="1.5" Background="#33FFFFFF" VerticalAlignment="Center">
                    <Border CornerRadius="1.5" Background="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="{Binding MediaProgress}" />
                        </Border.RenderTransform>
                    </Border>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding MediaPositionText}" Foreground="#66FFFFFF" FontSize="9"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </Grid>
        </StackPanel>
        <!-- No media placeholder -->
        <TextBlock Text="No media playing" Foreground="#44FFFFFF" FontSize="12"
                   VerticalAlignment="Center"
                   Visibility="{Binding HasMedia, Converter={StaticResource InverseBoolToVisibility}}" />
    </Grid>
</UserControl>

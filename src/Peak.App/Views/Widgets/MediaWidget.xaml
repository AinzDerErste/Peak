<UserControl x:Class="Peak.App.Views.Widgets.MediaWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Peak.App.Views.Widgets"
             FontFamily="{StaticResource InterFont}">
    <Grid VerticalAlignment="Top">
        <!-- Media controls -->
        <StackPanel Visibility="{Binding HasMedia, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Width="56" Height="56" Margin="0,0,10,0">
                    <Border CornerRadius="10">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding AlbumArt}" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <!-- LIVE overlay badge — centered on the bottom edge of the
                         artwork, hanging ~4px below it for a ribbon look. -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,-4"
                            Background="#FFE74C3C" CornerRadius="3" Padding="4,1"
                            Visibility="{Binding IsLiveStream, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="5" Height="5" Fill="White" VerticalAlignment="Center" Margin="0,0,4,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                From="1.0" To="0.35" Duration="0:0:0.9"
                                                                AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="LIVE" Foreground="White" FontSize="9" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontSize="13"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding MediaArtist}" Foreground="#88FFFFFF" FontSize="11"
                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                        <Button Command="{Binding PreviousTrackCommand}" Style="{StaticResource IconButton}" Focusable="False">
                            <Path Data="{StaticResource IconBackward}" Fill="White" Stretch="Uniform" Width="11" Height="11" />
                        </Button>
                        <Button Command="{Binding PlayPauseCommand}" Style="{StaticResource IconButton}" Margin="3,0" Focusable="False">
                            <Path Data="{Binding PlayPauseIcon}" Fill="White" Stretch="Uniform" Width="12" Height="12" />
                        </Button>
                        <Button Command="{Binding NextTrackCommand}" Style="{StaticResource IconButton}" Focusable="False">
                            <Path Data="{StaticResource IconForward}" Fill="White" Stretch="Uniform" Width="11" Height="11" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <!-- Progress bar + time (only for finite-duration tracks).
                 Time column has a fixed Width so the bar doesn't reflow as the
                 digits change (e.g. "1:23 / 3:45" → "12:34 / 12:34"). -->
            <Grid Margin="0,6,0,0"
                  Visibility="{Binding HasMediaProgress, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <!-- Track + fill. The fill uses an animated Width (not a
                     ScaleTransform) so its rounded corners stay at full radius
                     regardless of fill amount — at low progress, scaling would
                     shrink the left corner's horizontal radius to near-zero
                     and visually flatten it into a sharp edge. -->
                <Border x:Name="ProgressTrack" Height="5" CornerRadius="2.5"
                        Background="#33FFFFFF" VerticalAlignment="Center">
                    <Border x:Name="ProgressFill" CornerRadius="2.5"
                            Background="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Left" Width="0" />
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding MediaPositionText}" Foreground="#99FFFFFF" FontSize="10"
                           VerticalAlignment="Center" TextAlignment="Right" Margin="8,0,0,0" />
            </Grid>

        </StackPanel>
        <!-- No media placeholder -->
        <TextBlock Text="No media playing" Foreground="#44FFFFFF" FontSize="12"
                   VerticalAlignment="Center"
                   Visibility="{Binding HasMedia, Converter={StaticResource InverseBoolToVisibility}}" />
    </Grid>
</UserControl>

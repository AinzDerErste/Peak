<UserControl x:Class="Peak.App.Views.Widgets.PomodoroWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource InterFont}">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
        <!-- Phase label + completed session count -->
        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
            <TextBlock Text="{Binding PomodoroPhaseLabel}" Foreground="#AAFFFFFF" FontSize="10"
                       HorizontalAlignment="Right" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="#" Foreground="#66FFFFFF" FontSize="10" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PomodoroCompletedSessions}" Foreground="#AAFFFFFF" FontSize="10"
                           VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Countdown time -->
        <TextBlock Text="{Binding PomodoroText}" Foreground="White" FontSize="14"
                   VerticalAlignment="Center" FontWeight="SemiBold" FontFamily="Consolas"
                   Margin="0,0,8,0" />

        <!-- Start -->
        <Button Command="{Binding StartPomodoroCommand}" Style="{StaticResource TextIconButton}"
                Visibility="{Binding IsPomodoroRunning, Converter={StaticResource InverseBoolToVisibility}}">
            <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform"
                  Width="10" Height="10" VerticalAlignment="Center" />
        </Button>

        <!-- Pause -->
        <Button Command="{Binding PausePomodoroCommand}" Style="{StaticResource TextIconButton}"
                Visibility="{Binding IsPomodoroRunning, Converter={StaticResource BoolToVisibility}}">
            <Path Data="{StaticResource IconStop}" Fill="White" Stretch="Uniform"
                  Width="10" Height="10" VerticalAlignment="Center" />
        </Button>

        <!-- Skip -->
        <Button Command="{Binding SkipPomodoroCommand}" Style="{StaticResource TextIconButton}"
                ToolTip="Skip phase" Margin="2,0,0,0">
            <TextBlock Text="›|" Foreground="White" FontSize="12" VerticalAlignment="Center" />
        </Button>

        <!-- Reset -->
        <Button Command="{Binding ResetPomodoroCommand}" Style="{StaticResource TextIconButton}"
                ToolTip="Reset" Margin="2,0,0,0">
            <Path Data="{StaticResource IconArrowsRotate}" Fill="White" Stretch="Uniform"
                  Width="10" Height="10" VerticalAlignment="Center" />
        </Button>
    </StackPanel>
</UserControl>

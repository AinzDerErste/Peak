<UserControl x:Class="Peak.App.Views.Widgets.PomodoroWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource InterFont}">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                <GradientStop Color="{Binding PomodoroPhaseColor}" Offset="0" />
                <GradientStop Color="{Binding PomodoroPhaseColor}" Offset="{Binding PomodoroProgress}" />
                <GradientStop Color="#00000000" Offset="{Binding PomodoroProgress}" />
                <GradientStop Color="#00000000" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="8,0,8,0">
            <!-- Phase label + completed session count -->
            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="{Binding PomodoroPhaseLabel}" Foreground="#CCFFFFFF" FontSize="10"
                           HorizontalAlignment="Right" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding HasPomodoroSessions, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="#" Foreground="#66FFFFFF" FontSize="9" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding PomodoroCompletedSessions}" Foreground="#AAFFFFFF" FontSize="9"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- Countdown time -->
            <TextBlock Text="{Binding PomodoroText}" Foreground="White" FontSize="14"
                       VerticalAlignment="Center" FontWeight="SemiBold" FontFamily="Consolas"
                       Margin="0,0,8,0" />

            <!-- Start -->
            <Button Command="{Binding StartPomodoroCommand}" Style="{StaticResource TextIconButton}"
                    Visibility="{Binding IsPomodoroRunning, Converter={StaticResource InverseBoolToVisibility}}">
                <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform"
                      Width="10" Height="10" VerticalAlignment="Center" />
            </Button>

            <!-- Pause -->
            <Button Command="{Binding PausePomodoroCommand}" Style="{StaticResource TextIconButton}"
                    Visibility="{Binding IsPomodoroRunning, Converter={StaticResource BoolToVisibility}}">
                <Path Data="{StaticResource IconPause}" Fill="White" Stretch="Uniform"
                      Width="10" Height="10" VerticalAlignment="Center" />
            </Button>

            <!-- Skip (only when active) -->
            <Button Command="{Binding SkipPomodoroCommand}" Style="{StaticResource TextIconButton}"
                    ToolTip="Skip phase" Margin="2,0,0,0"
                    Visibility="{Binding IsPomodoroActive, Converter={StaticResource BoolToVisibility}}">
                <Path Data="{StaticResource IconForward}" Fill="White" Stretch="Uniform"
                      Width="10" Height="10" VerticalAlignment="Center" />
            </Button>

            <!-- Reset (only when active) -->
            <Button Command="{Binding ResetPomodoroCommand}" Style="{StaticResource TextIconButton}"
                    ToolTip="Reset" Margin="2,0,0,0"
                    Visibility="{Binding IsPomodoroActive, Converter={StaticResource BoolToVisibility}}">
                <Path Data="{StaticResource IconArrowsRotate}" Fill="White" Stretch="Uniform"
                      Width="10" Height="10" VerticalAlignment="Center" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>

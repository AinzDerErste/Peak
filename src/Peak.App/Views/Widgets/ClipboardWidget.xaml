<UserControl x:Class="Peak.App.Views.Widgets.ClipboardWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Peak.App.Views.Widgets"
             FontFamily="{StaticResource InterFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="2,0,4,4">
            <TextBlock Text="📋 Clipboard" Foreground="#88FFFFFF" FontSize="10" FontWeight="SemiBold"
                       DockPanel.Dock="Left" VerticalAlignment="Center" />
            <TextBlock Text="Clear" Foreground="#55FFFFFF" FontSize="9" Cursor="Hand"
                       DockPanel.Dock="Right" VerticalAlignment="Center"
                       MouseDown="OnClearAllClick" />
            <Rectangle />
        </DockPanel>

        <!-- Scrollable list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ClipboardHistory}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#15FFFFFF" CornerRadius="4" Padding="6,4" Margin="0,0,0,2"
                                Cursor="Hand" MouseDown="OnEntryClick" MouseEnter="OnEntryHover" MouseLeave="OnEntryLeave"
                                Tag="{Binding}">
                            <DockPanel>
                                <!-- Timestamp -->
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="8"
                                           Foreground="#44FFFFFF" Margin="6,0,0,0"
                                           Text="{Binding CopiedAt, StringFormat='{}{0:HH:mm}'}" />
                                <!-- Type icon + Preview -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontSize="9" Margin="0,0,4,0" VerticalAlignment="Center"
                                               Text="{Binding ContentType, Converter={x:Static local:ClipboardWidget.TypeIconConverter}}" />
                                    <TextBlock Text="{Binding DisplayText}" Foreground="White" FontSize="10"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               MaxWidth="160" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock Grid.Row="1" Text="No clipboard history" Foreground="#44FFFFFF" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding ClipboardHistory.Count, Converter={x:Static local:ClipboardWidget.EmptyConverter}}" />
    </Grid>
</UserControl>

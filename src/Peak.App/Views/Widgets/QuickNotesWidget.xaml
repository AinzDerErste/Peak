<UserControl x:Class="Peak.App.Views.Widgets.QuickNotesWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Peak.App.Views.Widgets"
             FontFamily="{StaticResource InterFont}">
    <Grid>
        <!-- List View -->
        <Grid x:Name="ListView">
            <!-- Header -->
            <DockPanel Margin="0,0,0,2">
                <TextBlock Text="Notes" Foreground="#88FFFFFF" FontSize="10" FontWeight="SemiBold"
                           DockPanel.Dock="Left" VerticalAlignment="Center" Margin="2,0,0,0" />
                <TextBlock Text="+" Foreground="#88FFFFFF" FontSize="14" FontWeight="Bold" Cursor="Hand"
                           DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                           MouseDown="OnAddNoteClick" />
                <Rectangle />
            </DockPanel>

            <!-- Notes list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Notes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#15FFFFFF" CornerRadius="4" Padding="6,3" Margin="0,0,0,2"
                                    Cursor="Hand" MouseDown="OnNoteClick" MouseEnter="OnNoteHover" MouseLeave="OnNoteLeave"
                                    Tag="{Binding}">
                                <DockPanel>
                                    <!-- Delete button -->
                                    <TextBlock Text="✕" Foreground="#44FFFFFF" FontSize="9" Cursor="Hand"
                                               DockPanel.Dock="Right" VerticalAlignment="Center" Margin="4,0,0,0"
                                               MouseDown="OnDeleteNoteClick" Tag="{Binding}" />
                                    <!-- Title -->
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="10"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Text="No notes yet" Foreground="#44FFFFFF" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding Notes.Count, Converter={x:Static local:QuickNotesWidget.EmptyConverter}}" />
        </Grid>

        <!-- Editor View -->
        <Grid x:Name="EditorView" Visibility="Collapsed">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock Text="←" Foreground="#88FFFFFF" FontSize="14" Cursor="Hand"
                               DockPanel.Dock="Left" VerticalAlignment="Center" Margin="2,0,6,0"
                               MouseDown="OnBackClick" />
                    <TextBlock Text="{Binding SelectedNote.Title}" Foreground="#88FFFFFF" FontSize="10"
                               FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </DockPanel>
                <TextBox x:Name="NoteEditor" Background="#0AFFFFFF" Foreground="White" FontSize="11"
                         BorderThickness="0" Padding="6,4" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" CaretBrush="White"
                         TextChanged="OnNoteTextChanged"
                         Text="{Binding SelectedNote.Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>

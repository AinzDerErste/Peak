<UserControl x:Class="Peak.App.Views.Widgets.NetworkWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource InterFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Speeds side by side -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Download -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="▼" Foreground="{DynamicResource AccentBrush}" FontSize="9"
                           VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBlock Text="{Binding DownloadSpeed}" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
            <!-- Upload -->
            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <TextBlock Text="▲" Foreground="#CCFFFFFF" FontSize="9"
                           VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBlock Text="{Binding UploadSpeed}" Foreground="#CCFFFFFF" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
        <!-- Graph fills remaining height -->
        <Border Grid.Row="1" CornerRadius="4" Background="#08FFFFFF" ClipToBounds="True">
            <Canvas x:Name="GraphCanvas" />
        </Border>
    </Grid>
</UserControl>

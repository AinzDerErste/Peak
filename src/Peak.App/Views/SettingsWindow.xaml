<Window x:Class="Peak.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="520" Height="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="DragWindow">

    <Window.Resources>
        <FontFamily x:Key="SegoeVar">Segoe UI Variable Display, Segoe UI, Arial</FontFamily>

        <!-- Colors -->
        <Color x:Key="BgColor">#FF1C1C1C</Color>
        <Color x:Key="CardColor">#FF2A2A2A</Color>
        <Color x:Key="AccentColor">#FF60CDFF</Color>
        <Color x:Key="AccentHoverColor">#FF4DB8E8</Color>
        <Color x:Key="BorderColor">#FF383838</Color>
        <Color x:Key="InputBgColor">#FF1A1A1A</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="InputBg" Color="{StaticResource InputBgColor}" />
        <SolidColorBrush x:Key="TextPrimary" Color="White" />
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA" />
        <SolidColorBrush x:Key="TextDim" Color="#666666" />

        <!-- Hidden Scrollbar -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter Margin="{TemplateBinding Padding}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Orientation="Vertical" HorizontalAlignment="Right"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Width="6" Margin="0,2,2,2" Opacity="0.3">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#888" CornerRadius="3" />
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0.5" />
        </Style>

        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Margin" Value="2,18,0,8" />
        </Style>

        <!-- Label -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Sublabel -->
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextDim}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- Toggle Switch -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="44" Height="22" Cursor="Hand" VerticalAlignment="Center">
                            <Border x:Name="Track" CornerRadius="11" Background="#FF555555" />
                            <Border x:Name="ThumbOff" Width="16" Height="16" CornerRadius="8"
                                    Background="#FFCCCCCC" HorizontalAlignment="Left" Margin="3,0,0,0"
                                    VerticalAlignment="Center" Visibility="Visible" />
                            <Border x:Name="ThumbOn" Width="16" Height="16" CornerRadius="8"
                                    Background="White" HorizontalAlignment="Right" Margin="0,0,3,0"
                                    VerticalAlignment="Center" Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ThumbOff" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ThumbOn" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{StaticResource InputBg}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="12,8,10,8" SnapsToDevicePixels="True"
                                    Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <Path Grid.Column="1" Data="M0,0 L5,5 10,0" Stroke="#999" StrokeThickness="1.5"
                                          VerticalAlignment="Center" Margin="8,0,2,0" />
                                    <ToggleButton Grid.ColumnSpan="2" Focusable="False" Opacity="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" />
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#FF2A2A2A" BorderBrush="#FF444444"
                                        BorderThickness="1" CornerRadius="8" Padding="4,6"
                                        Margin="0,4,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer SnapsToDevicePixels="True" VerticalScrollBarVisibility="Hidden">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#555" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider with fill track -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Height" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <!-- Background track -->
                            <Border Height="4" CornerRadius="2" Background="#FF444444" VerticalAlignment="Center" />
                            <!-- Filled track (accent) -->
                            <Canvas Height="4" VerticalAlignment="Center" ClipToBounds="True">
                                <Border x:Name="FillTrack" Height="4" CornerRadius="2"
                                        Background="{StaticResource AccentBrush}" Width="0" />
                            </Canvas>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Fill="{StaticResource AccentBrush}" Width="20" Height="20" />
                                                    <Ellipse Fill="White" Width="8" Height="8" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent Button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF000000" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{StaticResource AccentBrush}"
                                CornerRadius="6" Padding="24,9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle Button -->
        <Style x:Key="SubtleButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource SegoeVar}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#FF333333" CornerRadius="6" Padding="24,9"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF404040" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator inside cards -->
        <Style x:Key="CardSep" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="#FF333333" />
            <Setter Property="Margin" Value="-16,10,-16,10" />
        </Style>
    </Window.Resources>

    <!-- Window border with shadow simulation -->
    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.5" Color="Black" />
        </Border.Effect>
        <Border CornerRadius="12" Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ═══ TITLE BAR ═══ -->
                <Grid Grid.Row="0" Margin="24,20,20,0">
                    <StackPanel>
                        <TextBlock Text="Settings" FontFamily="{StaticResource SegoeVar}"
                                   FontSize="28" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="Peak — Dynamic Island for Windows" FontFamily="{StaticResource SegoeVar}"
                                   FontSize="12" Foreground="{StaticResource TextDim}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="OnCancelClick" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Width="34" Height="34" CornerRadius="8" Background="Transparent">
                                    <TextBlock Text="✕" Foreground="#777" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ═══ CONTENT ═══ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="24,4,24,0">
                    <StackPanel>

                        <!-- General -->
                        <TextBlock Text="GENERAL" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <TextBlock Text="Always visible" Style="{StaticResource Label}" />
                                        <TextBlock x:Name="BehaviorHint" Style="{StaticResource SubLabel}"
                                                   Text="Island is always shown on screen" />
                                    </StackPanel>
                                    <CheckBox x:Name="AlwaysVisibleCheck" Style="{StaticResource ToggleSwitch}"
                                              HorizontalAlignment="Right" IsChecked="True"
                                              Checked="OnAlwaysVisibleChanged" Unchecked="OnAlwaysVisibleChanged" />
                                </DockPanel>

                                <Border Style="{StaticResource CardSep}" />

                                <StackPanel>
                                    <TextBlock Style="{StaticResource Label}">
                                        <Run Text="Auto-collapse after " />
                                        <Run Text="{Binding ElementName=CollapseSlider, Path=Value, StringFormat={}{0:F0}}" />
                                        <Run Text=" seconds" />
                                    </TextBlock>
                                    <Slider x:Name="CollapseSlider" Style="{StaticResource ModernSlider}"
                                            Minimum="2" Maximum="15" Value="5"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            Margin="0,10,0,0" />
                                </StackPanel>

                                <Border Style="{StaticResource CardSep}" />

                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <TextBlock Text="Start with Windows" Style="{StaticResource Label}" />
                                        <TextBlock Text="Launch automatically on login" Style="{StaticResource SubLabel}" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoStartCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Appearance -->
                        <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Show island border" Style="{StaticResource Label}" />
                                    <TextBlock Text="Subtle outline around the island" Style="{StaticResource SubLabel}" />
                                </StackPanel>
                                <CheckBox x:Name="ShowBorderCheck" Style="{StaticResource ToggleSwitch}"
                                          HorizontalAlignment="Right" IsChecked="True" />
                            </DockPanel>
                        </Border>

                        <!-- Colors -->
                        <TextBlock Text="COLORS" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <!-- Background Color -->
                                <TextBlock Text="Background" Style="{StaticResource Label}" />
                                <TextBlock Text="Island background color" Style="{StaticResource SubLabel}" Margin="0,2,0,8" />
                                <WrapPanel x:Name="BgColorPanel" Orientation="Horizontal">
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF000000"
                                             Fill="#FF000000" Stroke="#55FFFFFF" StrokeThickness="1.5"
                                             MouseDown="OnBgColorClick" ToolTip="Schwarz" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF1A1A1A"
                                             Fill="#FF1A1A1A" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnBgColorClick" ToolTip="Anthrazit" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF2D2D2D"
                                             Fill="#FF2D2D2D" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnBgColorClick" ToolTip="Dunkelgrau" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF0D1B2A"
                                             Fill="#FF0D1B2A" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnBgColorClick" ToolTip="Navy" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF0A1F0A"
                                             Fill="#FF0A1F0A" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnBgColorClick" ToolTip="Dunkelgrün" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF1A0A0A"
                                             Fill="#FF1A0A0A" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnBgColorClick" ToolTip="Bordeaux" />
                                </WrapPanel>
                                <DockPanel Margin="0,2,0,0">
                                    <Ellipse x:Name="BgPreview" Width="24" Height="24" DockPanel.Dock="Left"
                                             Fill="#FF000000" Stroke="#33FFFFFF" StrokeThickness="1"
                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="BgHexBox" Style="{StaticResource ModernTextBox}"
                                             Text="#FF000000" MaxLength="9" FontSize="12"
                                             TextChanged="OnBgHexChanged" />
                                </DockPanel>

                                <Border Style="{StaticResource CardSep}" />

                                <!-- Accent Color -->
                                <TextBlock Text="Accent" Style="{StaticResource Label}" />
                                <TextBlock Text="Highlights, progress bars, buttons" Style="{StaticResource SubLabel}" Margin="0,2,0,8" />
                                <WrapPanel x:Name="AccentColorPanel" Orientation="Horizontal">
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF60CDFF"
                                             Fill="#FF60CDFF" Stroke="#FFFFFFFF" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Blau" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF4CAF50"
                                             Fill="#FF4CAF50" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Grün" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FFFF9800"
                                             Fill="#FFFF9800" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Orange" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FFFF4081"
                                             Fill="#FFFF4081" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Pink" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FFB388FF"
                                             Fill="#FFB388FF" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Lila" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FFEF5350"
                                             Fill="#FFEF5350" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Rot" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FFFFEB3B"
                                             Fill="#FFFFEB3B" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Gelb" />
                                    <Ellipse Width="28" Height="28" Margin="0,0,8,8" Cursor="Hand" Tag="#FF26A69A"
                                             Fill="#FF26A69A" Stroke="Transparent" StrokeThickness="1.5"
                                             MouseDown="OnAccentColorClick" ToolTip="Teal" />
                                </WrapPanel>
                                <DockPanel Margin="0,2,0,0">
                                    <Ellipse x:Name="AccentPreview" Width="24" Height="24" DockPanel.Dock="Left"
                                             Fill="#FF60CDFF" Stroke="#33FFFFFF" StrokeThickness="1"
                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="AccentHexBox" Style="{StaticResource ModernTextBox}"
                                             Text="#FF60CDFF" MaxLength="9" FontSize="12"
                                             TextChanged="OnAccentHexChanged" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Collapsed Layout -->
                        <TextBlock Text="COLLAPSED LAYOUT" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Configure what the island shows when collapsed" Style="{StaticResource SubLabel}" Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Left" Foreground="#999" FontSize="11" Margin="0,0,0,4" />
                                        <ComboBox x:Name="CollapsedLeftCombo" Style="{StaticResource ModernComboBox}" MinWidth="0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Center" Foreground="#999" FontSize="11" Margin="0,0,0,4" />
                                        <ComboBox x:Name="CollapsedCenterCombo" Style="{StaticResource ModernComboBox}" MinWidth="0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Right" Foreground="#999" FontSize="11" Margin="0,0,0,4" />
                                        <ComboBox x:Name="CollapsedRightCombo" Style="{StaticResource ModernComboBox}" MinWidth="0" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Audio -->
                        <TextBlock Text="AUDIO" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Audio Device" Style="{StaticResource Label}" />
                                <TextBlock Text="Device used for music visualizer" Style="{StaticResource SubLabel}" Margin="0,2,0,8" />
                                <ComboBox x:Name="AudioDeviceCombo" Style="{StaticResource ModernComboBox}" />

                                <Border Style="{StaticResource CardSep}" />

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Sensitivity: " Style="{StaticResource Label}" />
                                    <TextBlock x:Name="SensitivityLabel" Text="50%" Style="{StaticResource Label}" />
                                </StackPanel>
                                <TextBlock Text="How reactive the visualizer bars are" Style="{StaticResource SubLabel}" Margin="0,2,0,6" />
                                <Slider x:Name="SensitivitySlider" Style="{StaticResource ModernSlider}"
                                        Minimum="10" Maximum="100" Value="50"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        ValueChanged="OnSensitivityChanged" />
                            </StackPanel>
                        </Border>

                        <!-- Widgets -->
                        <TextBlock Text="WIDGETS" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Clock" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowClockCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="True" />
                                </DockPanel>
                                <Border Style="{StaticResource CardSep}" />
                                <DockPanel>
                                    <TextBlock Text="Weather" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowWeatherCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="True" />
                                </DockPanel>
                                <Border Style="{StaticResource CardSep}" />
                                <DockPanel>
                                    <TextBlock Text="Media Controls" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowMediaCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="True" />
                                </DockPanel>
                                <Border Style="{StaticResource CardSep}" />
                                <DockPanel>
                                    <TextBlock Text="System Monitor" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowSystemCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="True" />
                                </DockPanel>
                                <Border Style="{StaticResource CardSep}" />
                                <DockPanel>
                                    <TextBlock Text="Calendar" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowCalendarCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="True" />
                                </DockPanel>
                                <Border Style="{StaticResource CardSep}" />
                                <DockPanel>
                                    <TextBlock Text="Notifications" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowNotificationsCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="True" />
                                </DockPanel>
                                <Border Style="{StaticResource CardSep}" />
                                <DockPanel>
                                    <TextBlock Text="Timer" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowTimerCheck" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="True" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Weather Location -->
                        <TextBlock Text="WEATHER" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Postal Code" Style="{StaticResource Label}" Margin="0,0,0,6" />
                                <TextBox x:Name="PostalCodeBox" Style="{StaticResource ModernTextBox}" />

                                <TextBlock Text="Country Code" Style="{StaticResource Label}" Margin="0,14,0,6" />
                                <TextBox x:Name="CountryCodeBox" Style="{StaticResource ModernTextBox}" />

                                <TextBlock Text="Leave empty for automatic IP-based detection"
                                           Style="{StaticResource SubLabel}" FontStyle="Italic" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- ═══ ABOUT ═══ -->
                        <Border Style="{StaticResource SectionCard}" Margin="24,18,24,0">
                            <StackPanel>
                                <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" />

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Peak" FontFamily="{StaticResource SegoeVar}"
                                               FontSize="16" FontWeight="SemiBold" Foreground="White" />
                                    <TextBlock x:Name="VersionText" FontFamily="{StaticResource SegoeVar}"
                                               FontSize="16" Foreground="{StaticResource TextDim}" Margin="8,0,0,0" />
                                </StackPanel>

                                <TextBlock Text="Dynamic Island for Windows" Style="{StaticResource SubLabel}" Margin="0,4,0,0" />

                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button x:Name="CheckUpdateButton" Content="Check for Updates"
                                            Style="{StaticResource SubtleButton}" Width="150" Click="OnCheckUpdateClick" />
                                    <TextBlock x:Name="UpdateStatusText" FontFamily="{StaticResource SegoeVar}"
                                               FontSize="12" Foreground="{StaticResource TextDim}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Bottom spacing -->
                        <Border Height="8" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ═══ FOOTER BUTTONS ═══ -->
                <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0.5,0,0"
                        Padding="24,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                                Width="100" Click="OnCancelClick" />
                        <Button Content="Save" Style="{StaticResource AccentButton}"
                                Width="100" Margin="8,0,0,0" Click="OnSaveClick" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>

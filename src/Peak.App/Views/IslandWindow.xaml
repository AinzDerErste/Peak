<Window x:Class="Peak.App.Views.IslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Peak.App.ViewModels"
        xmlns:w="clr-namespace:Peak.App.Views.Widgets"
        xmlns:cfg="clr-namespace:Peak.Core.Configuration;assembly=Peak.Core"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        AllowDrop="True"
        FontFamily="{StaticResource InterFont}">

    <Window.Resources>
        <!-- Easing -->
        <CubicEase x:Key="CubicEaseInOut" EasingMode="EaseInOut" />

        <!-- Widget DataTemplates keyed by WidgetType -->
        <DataTemplate x:Key="ClockTemplate"><w:ClockWidget /></DataTemplate>
        <DataTemplate x:Key="WeatherTemplate"><w:WeatherWidget /></DataTemplate>
        <DataTemplate x:Key="MediaTemplate"><w:MediaWidget /></DataTemplate>
        <DataTemplate x:Key="SystemMonitorTemplate"><w:SystemMonitorWidget /></DataTemplate>
        <DataTemplate x:Key="CalendarTemplate"><w:CalendarWidget /></DataTemplate>
        <DataTemplate x:Key="TimerTemplate"><w:TimerWidget /></DataTemplate>
        <DataTemplate x:Key="NetworkTemplate"><w:NetworkWidget /></DataTemplate>
        <DataTemplate x:Key="QuickAccessTemplate"><w:QuickAccessWidget /></DataTemplate>
        <DataTemplate x:Key="ClipboardTemplate"><w:ClipboardWidget /></DataTemplate>
        <DataTemplate x:Key="QuickNotesTemplate"><w:QuickNotesWidget /></DataTemplate>
        <DataTemplate x:Key="NoneTemplate"><Border /></DataTemplate>

        <!-- Dark Toggle Button for ComboBox -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Border x:Name="Bd" Background="#FF0A0A0A" BorderBrush="#55FFFFFF" BorderThickness="1"
                    CornerRadius="6" Padding="8,4">
                <Grid>
                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <Path x:Name="Arrow" Data="M0,0 L4,4 8,0" Stroke="#AAFFFFFF" StrokeThickness="1.5"
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,1,2,0" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#CC3A3A3A" />
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#88FFFFFF" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#CC3A3A3A" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Dark ComboBoxItem -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#44FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Edit Mode Slot ComboBox (fully dark themed) -->
        <Style x:Key="SlotComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press" />
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Background="#F0050505" BorderBrush="#55FFFFFF"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="2,4" Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid UseLayoutRounding="True" SnapsToDevicePixels="True"
          TextOptions.TextFormattingMode="Display">

        <!-- Main Island Border -->
        <Border x:Name="IslandBorder"
                MinWidth="200" MinHeight="30"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Padding="16,8"
                ClipToBounds="True"
                Cursor="Arrow"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True"
                BorderBrush="#22FFFFFF"
                BorderThickness="0.5"
                Background="{DynamicResource IslandBackgroundBrush}">
            <Border.CacheMode>
                <BitmapCache EnableClearType="True" SnapsToDevicePixels="True" />
            </Border.CacheMode>

            <Grid>
                <!-- Collapsed: 3 configurable slots (Left / Center / Right) + visualizer -->
                <StackPanel x:Name="CollapsedContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ContentControl x:Name="CollapsedSlotLeft" VerticalAlignment="Center" />
                    <Ellipse x:Name="CollapsedSep1" Width="3" Height="3" Fill="#55FFFFFF" Margin="12,0" VerticalAlignment="Center" Visibility="Collapsed" />
                    <ContentControl x:Name="CollapsedSlotCenter" VerticalAlignment="Center" />
                    <Ellipse x:Name="CollapsedSep2" Width="3" Height="3" Fill="#55FFFFFF" Margin="12,0" VerticalAlignment="Center" Visibility="Collapsed" />
                    <ContentControl x:Name="CollapsedSlotRight" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Greeting text shown briefly when unhiding -->
                <TextBlock x:Name="GreetingText"
                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Margin="12,0"
                           Visibility="Collapsed" Opacity="0" />

                <!-- Peek: Brief info (media / notification) -->
                <Grid x:Name="PeekContent" Visibility="Collapsed"
                      Background="Transparent"
                      MouseLeftButtonUp="OnPeekLeftClick"
                      MouseRightButtonUp="OnPeekRightClick"
                      Cursor="Hand">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Album art (media, hidden when notification active).
                         38×38 thumbnail in the 56px peek pill: top/bottom gap
                         to the pill's outer edge is ~9px (8px padding +
                         0.5px border + 0.5px vertical centring). Left margin
                         of -7 trims the IslandBorder's 16px horizontal
                         padding to a matching ~9px on the left, so the icon
                         is visually equidistant from three pill edges.
                         VerticalAlignment=Center keeps it pinned to the
                         cell's midline if the neighbouring text grows. -->
                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10"
                            VerticalAlignment="Center"
                            Margin="-7,0,12,0" Visibility="{Binding PeekShowsMedia, Converter={StaticResource BoolToVisibility}}">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding AlbumArt}" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>

                    <!-- App icon (notification) -->
                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="8"
                            Margin="0,0,12,0" Visibility="{Binding HasNotification, Converter={StaticResource BoolToVisibility}}">
                        <Image Source="{Binding NotificationIcon}" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" MaxWidth="260">
                        <!-- Media info (hidden when notification active) -->
                        <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontSize="13"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding PeekShowsMedia, Converter={StaticResource BoolToVisibility}}" />
                        <TextBlock Text="{Binding MediaArtist}" Foreground="#99FFFFFF" FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding PeekShowsMedia, Converter={StaticResource BoolToVisibility}}" />
                        <!-- Notification info: app name + title + body -->
                        <StackPanel Visibility="{Binding HasNotification, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding NotificationApp}" Foreground="#66FFFFFF" FontSize="10"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding NotificationTitle}" Foreground="White" FontSize="13"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding NotificationBody}" Foreground="#99FFFFFF" FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="{Binding CurrentTime}" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding WeatherTemp}" Foreground="#77FFFFFF" FontSize="10"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <!-- Expanded: Dynamic Widget Stack (rows collapse when empty) -->
                <StackPanel x:Name="ExpandedContent" Visibility="Collapsed">

                    <!-- Row 0 -->
                    <DockPanel x:Name="WidgetRow0" Height="60">
                        <Border x:Name="RowToggle0" DockPanel.Dock="Left" Width="18" Margin="0,0,4,0"
                                Visibility="Collapsed" Cursor="Hand" MouseDown="OnRowToggleClick" Tag="0"
                                ToolTip="Toggle wide/split">
                            <TextBlock x:Name="RowToggleIcon0" Text="⇔" Foreground="#66FFFFFF" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Grid x:Name="WidgetGrid0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition x:Name="Col1Row0" Width="*" />
                            </Grid.ColumnDefinitions>
                            <ContentControl x:Name="SlotHost0" Grid.Column="0" Margin="0,4,6,4" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                            <ContentControl x:Name="SlotHost1" Grid.Column="1" Margin="6,4,0,4" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                            <!-- Header-content overlay — populated by plugins via
                                 IIslandHost.SetExpandedHeaderContent. Spans both columns
                                 and centers itself between them, so a small companion
                                 widget sits visually between Clock (slot 0) and Weather
                                 (slot 1) without resizing either slot. -->
                            <ContentControl x:Name="ExpandedHeaderHost" Grid.Column="0" Grid.ColumnSpan="2"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            IsHitTestVisible="True" />
                            <Border x:Name="EditOverlay0" Grid.Column="0" Background="#F0050505" CornerRadius="8" Margin="0,0,6,0"
                                    Visibility="Collapsed" Cursor="Hand" MouseDown="OnEditSlotClick" Tag="0"
                                    AllowDrop="True" DragOver="OnEditOverlayDragOver" Drop="OnEditOverlayDrop"
                                    DragEnter="OnEditOverlayDragEnter" DragLeave="OnEditOverlayDragLeave">
                                <Grid>
                                    <ComboBox Style="{StaticResource SlotComboBox}" Tag="0"
                                              ItemsSource="{Binding AvailableWidgets}" SelectedItem="{Binding Slot0}"
                                              SelectionChanged="OnSlotSelectionChanged" />
                                    <TextBlock Text="⠿" Foreground="#55FFFFFF" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                               Cursor="SizeAll" MouseDown="OnDragHandleMouseDown" Tag="0"
                                               ToolTip="Drag to swap" />
                                </Grid>
                            </Border>
                            <Border x:Name="EditOverlay1" Grid.Column="1" Background="#F0050505" CornerRadius="8" Margin="6,0,0,0"
                                    Visibility="Collapsed" Tag="1"
                                    AllowDrop="True" DragOver="OnEditOverlayDragOver" Drop="OnEditOverlayDrop"
                                    DragEnter="OnEditOverlayDragEnter" DragLeave="OnEditOverlayDragLeave">
                                <Grid>
                                    <ComboBox Style="{StaticResource SlotComboBox}" Tag="1"
                                              ItemsSource="{Binding AvailableWidgets}" SelectedItem="{Binding Slot1}"
                                              SelectionChanged="OnSlotSelectionChanged" />
                                    <TextBlock Text="⠿" Foreground="#55FFFFFF" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                               Cursor="SizeAll" MouseDown="OnDragHandleMouseDown" Tag="1"
                                               ToolTip="Drag to swap" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DockPanel>

                    <!-- Notification Banner (between Row 0 and Row 1) -->
                    <Border x:Name="NotificationBanner" Visibility="Collapsed"
                            Background="#22FFFFFF" CornerRadius="10" Padding="12,8" Margin="0,6"
                            Cursor="Hand"
                            MouseLeftButtonUp="OnPeekLeftClick"
                            MouseRightButtonUp="OnPeekRightClick">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding NotificationApp}" Foreground="#66FFFFFF" FontSize="9"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding NotificationTitle}" Foreground="White" FontSize="12"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding NotificationBody}" Foreground="#99FFFFFF" FontSize="10.5"
                                       TextTrimming="CharacterEllipsis" MaxHeight="28" />
                        </StackPanel>
                    </Border>

                    <!-- Separator 0-1 -->
                    <Border x:Name="Separator01" Height="1" Background="#22FFFFFF" Margin="0,8" />

                    <!-- Row 1 -->
                    <DockPanel x:Name="WidgetRow1" Height="60">
                        <Border x:Name="RowToggle1" DockPanel.Dock="Left" Width="18" Margin="0,0,4,0"
                                Visibility="Collapsed" Cursor="Hand" MouseDown="OnRowToggleClick" Tag="1"
                                ToolTip="Toggle wide/split">
                            <TextBlock x:Name="RowToggleIcon1" Text="⇔" Foreground="#66FFFFFF" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Grid x:Name="WidgetGrid1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition x:Name="Col1Row1" Width="*" />
                            </Grid.ColumnDefinitions>
                            <ContentControl x:Name="SlotHost2" Grid.Column="0" Margin="0,4,6,4" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                            <ContentControl x:Name="SlotHost3" Grid.Column="1" Margin="6,4,0,4" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                            <Border x:Name="EditOverlay2" Grid.Column="0" Background="#F0050505" CornerRadius="8" Margin="0,0,6,0"
                                    Visibility="Collapsed" Tag="2"
                                    AllowDrop="True" DragOver="OnEditOverlayDragOver" Drop="OnEditOverlayDrop"
                                    DragEnter="OnEditOverlayDragEnter" DragLeave="OnEditOverlayDragLeave">
                                <Grid>
                                    <ComboBox Style="{StaticResource SlotComboBox}" Tag="2"
                                              ItemsSource="{Binding AvailableWidgets}" SelectedItem="{Binding Slot2}"
                                              SelectionChanged="OnSlotSelectionChanged" />
                                    <TextBlock Text="⠿" Foreground="#55FFFFFF" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                               Cursor="SizeAll" MouseDown="OnDragHandleMouseDown" Tag="2"
                                               ToolTip="Drag to swap" />
                                </Grid>
                            </Border>
                            <Border x:Name="EditOverlay3" Grid.Column="1" Background="#F0050505" CornerRadius="8" Margin="6,0,0,0"
                                    Visibility="Collapsed" Tag="3"
                                    AllowDrop="True" DragOver="OnEditOverlayDragOver" Drop="OnEditOverlayDrop"
                                    DragEnter="OnEditOverlayDragEnter" DragLeave="OnEditOverlayDragLeave">
                                <Grid>
                                    <ComboBox Style="{StaticResource SlotComboBox}" Tag="3"
                                              ItemsSource="{Binding AvailableWidgets}" SelectedItem="{Binding Slot3}"
                                              SelectionChanged="OnSlotSelectionChanged" />
                                    <TextBlock Text="⠿" Foreground="#55FFFFFF" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                               Cursor="SizeAll" MouseDown="OnDragHandleMouseDown" Tag="3"
                                               ToolTip="Drag to swap" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DockPanel>

                    <!-- Separator 1-2 -->
                    <Border x:Name="Separator12" Height="1" Background="#22FFFFFF" Margin="0,8" />

                    <!-- Row 2 -->
                    <DockPanel x:Name="WidgetRow2" Height="60">
                        <Border x:Name="RowToggle2" DockPanel.Dock="Left" Width="18" Margin="0,0,4,0"
                                Visibility="Collapsed" Cursor="Hand" MouseDown="OnRowToggleClick" Tag="2"
                                ToolTip="Toggle wide/split">
                            <TextBlock x:Name="RowToggleIcon2" Text="⇔" Foreground="#66FFFFFF" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Grid x:Name="WidgetGrid2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition x:Name="Col1Row2" Width="*" />
                            </Grid.ColumnDefinitions>
                            <ContentControl x:Name="SlotHost4" Grid.Column="0" Margin="0,4,6,4" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                            <ContentControl x:Name="SlotHost5" Grid.Column="1" Margin="6,4,0,4" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                            <Border x:Name="EditOverlay4" Grid.Column="0" Background="#F0050505" CornerRadius="8" Margin="0,0,6,0"
                                    Visibility="Collapsed" Tag="4"
                                    AllowDrop="True" DragOver="OnEditOverlayDragOver" Drop="OnEditOverlayDrop"
                                    DragEnter="OnEditOverlayDragEnter" DragLeave="OnEditOverlayDragLeave">
                                <Grid>
                                    <ComboBox Style="{StaticResource SlotComboBox}" Tag="4"
                                              ItemsSource="{Binding AvailableWidgets}" SelectedItem="{Binding Slot4}"
                                              SelectionChanged="OnSlotSelectionChanged" />
                                    <TextBlock Text="⠿" Foreground="#55FFFFFF" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                               Cursor="SizeAll" MouseDown="OnDragHandleMouseDown" Tag="4"
                                               ToolTip="Drag to swap" />
                                </Grid>
                            </Border>
                            <Border x:Name="EditOverlay5" Grid.Column="1" Background="#F0050505" CornerRadius="8" Margin="6,0,0,0"
                                    Visibility="Collapsed" Tag="5"
                                    AllowDrop="True" DragOver="OnEditOverlayDragOver" Drop="OnEditOverlayDrop"
                                    DragEnter="OnEditOverlayDragEnter" DragLeave="OnEditOverlayDragLeave">
                                <Grid>
                                    <ComboBox Style="{StaticResource SlotComboBox}" Tag="5"
                                              ItemsSource="{Binding AvailableWidgets}" SelectedItem="{Binding Slot5}"
                                              SelectionChanged="OnSlotSelectionChanged" />
                                    <TextBlock Text="⠿" Foreground="#55FFFFFF" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                               Cursor="SizeAll" MouseDown="OnDragHandleMouseDown" Tag="5"
                                               ToolTip="Drag to swap" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DockPanel>

                    <!-- Done Button (Edit Mode) -->
                    <Button x:Name="EditDoneButton"
                            Content="Done" Style="{StaticResource TextIconButton}"
                            HorizontalAlignment="Right" Margin="0,6,0,0"
                            Visibility="Collapsed"
                            Command="{Binding ExitEditModeCommand}" />
                </StackPanel>

                <!-- Spotlight: search field + result list, takes the whole pill in Spotlight state.
                     Symmetric vertical margin so the search bar is visually centered inside the
                     IslandBorder padding when the results list is empty. -->
                <!-- Spotlight overrides IslandBorder.Padding to a uniform 6px at
                     runtime (see SetContentVisibility) so the dark chrome hugs
                     the search bar tight on all four sides.

                     VerticalAlignment="Top" not "Center" — during the resize
                     animation, if results suddenly grow the IslandBorder hasn't
                     reached its target height yet, so center-aligning the
                     larger Spotlight content would briefly push the search
                     bar above the border's top edge and clip it. Top-anchoring
                     keeps the search bar pinned at the top while results fill
                     in below. -->
                <Grid x:Name="SpotlightContent" Visibility="Collapsed"
                      VerticalAlignment="Top">
                    <!-- Both rows Auto so the Grid sizes to its actual content. A `*` row
                         here would silently consume the IslandBorder's leftover height,
                         producing the asymmetric "search bar at top, empty space below"
                         look when the result list is collapsed. VerticalAlignment="Center"
                         then evenly distributes any leftover IslandBorder height. -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Query input — Height pinned so the IslandBorder math in
                         IslandWindow.xaml.cs (SpotlightSearchBarHeight) lines up
                         with what's actually rendered, no font/DPI guesswork.
                         CornerRadius = outer pill radius (18) − Spotlight padding (6)
                         so the inner curve sits flush inside the outer curve. -->
                    <Border Grid.Row="0" Background="#10FFFFFF" CornerRadius="12"
                            Padding="12,0" Height="36">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconSearch}"
                                  Fill="#99FFFFFF" Stretch="Uniform" Width="14" Height="14"
                                  VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Grid Grid.Column="1">
                                <!-- Placeholder shown when query is empty -->
                                <TextBlock Text="Search apps…" Foreground="#66FFFFFF" FontSize="14"
                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="SpotlightInput"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" Foreground="White" CaretBrush="White"
                                         BorderThickness="0" FontSize="14" VerticalAlignment="Center"
                                         Focusable="True" IsTabStop="True"
                                         KeyDown="OnSpotlightInputKeyDown" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Subtle divider between search bar and results. Sits at top of Row 1
                         with 8px margin above. Only visible when there are matches; the
                         ListBox below has a matching top margin (8 + 1 + 8 = 17) so its
                         first item starts cleanly below the divider. -->
                    <Border Grid.Row="1" Height="1" Background="#20FFFFFF"
                            Margin="12,8,12,0" VerticalAlignment="Top"
                            Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibility}}" />

                    <!-- "No matches" hint when query has text but nothing found -->
                    <TextBlock Grid.Row="1" Text="No matches" Foreground="#66FFFFFF"
                               FontSize="13" Margin="12,12,0,0"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Visibility="{Binding ShowNoMatchesHint, Converter={StaticResource BoolToVisibility}}" />

                    <!-- Result list -->
                    <ListBox x:Name="SpotlightResults" Grid.Row="1"
                             ItemsSource="{Binding SearchResults}"
                             SelectedItem="{Binding SelectedSearchResult}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" Margin="0,17,0,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibility}}"
                             MouseDoubleClick="OnSpotlightResultDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <!-- Result rows mirror the search bar's design language:
                                 same Height (36) and CornerRadius (12), same horizontal
                                 inner padding (12), same #10FFFFFF tinted background
                                 family. Default rows are transparent so the highlighted
                                 (selected/hovered) row reads clearly. -->
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="36" />
                                <Setter Property="Padding" Value="12,0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding Path, Converter={StaticResource PathToIconConverter}, ConverterParameter=32}"
                                           Width="20" Height="20" Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <!-- Separate visualizer circle (positioned right of pill via code-behind) -->
        <Border x:Name="VisualizerCircle"
                Width="{Binding ActualHeight, ElementName=IslandBorder}"
                Height="{Binding ActualHeight, ElementName=IslandBorder}"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed" ClipToBounds="True"
                BorderBrush="#22FFFFFF" BorderThickness="0.5"
                Background="{DynamicResource IslandBackgroundBrush}">
            <Canvas x:Name="VisualizerRight" Width="22" Height="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>

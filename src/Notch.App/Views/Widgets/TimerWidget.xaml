<UserControl x:Class="Notch.App.Views.Widgets.TimerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource InterFont}">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
        <TextBlock Text="{Binding TimerText}" Foreground="White" FontSize="14"
                   VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"
                   FontFamily="Consolas"
                   Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVisibility}}" />
        <!-- Start -->
        <Button Command="{Binding StartTimerCommand}" Style="{StaticResource TextIconButton}"
                Visibility="{Binding IsTimerRunning, Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform"
                      Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBlock Text="Start" Foreground="White" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
        <!-- Stop -->
        <Button Command="{Binding StopTimerCommand}" Style="{StaticResource TextIconButton}"
                Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconStop}" Fill="White" Stretch="Uniform"
                      Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBlock Text="Stop" Foreground="White" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>

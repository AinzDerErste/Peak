<UserControl x:Class="Notch.App.Views.Widgets.CalendarWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource InterFont}">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                Visibility="{Binding HasNextEvent, Converter={StaticResource BoolToVisibility}}">
        <Path Data="{StaticResource IconCalendar}" Fill="#BBFFFFFF" Stretch="Uniform"
              Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,6,0" />
        <TextBlock Text="{Binding NextEventText}" Foreground="#BBFFFFFF" FontSize="12"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
    </StackPanel>
</UserControl>

<UserControl x:Class="Notch.App.Views.Widgets.QuickAccessWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Notch.App.Views.Widgets"
             FontFamily="{StaticResource InterFont}"
             AllowDrop="True"
             Drop="OnDrop" DragOver="OnDragOver">
    <Grid MinHeight="50">
        <!-- Normal content -->
        <Grid x:Name="ContentGrid">
            <!-- Items -->
            <ItemsControl ItemsSource="{Binding QuickAccessItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="6" Padding="6,4"
                                Margin="0,0,4,4" Cursor="Hand"
                                MouseDown="OnItemClick" MouseEnter="OnItemHover" MouseLeave="OnItemLeave"
                                ToolTip="{Binding Path}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name, Converter={x:Static local:QuickAccessWidget.IconConverter}}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="100" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state: Add button -->
            <TextBlock x:Name="EmptyHint" Text="+ Add files" Foreground="#55FFFFFF" FontSize="11"
                       Cursor="Hand" MouseDown="OnAddClick"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- Drop highlight overlay (fills entire widget area, dashed border) -->
        <Border x:Name="DropHighlight" CornerRadius="8" Background="#22FFFFFF"
                Visibility="Collapsed" IsHitTestVisible="False">
            <Grid>
                <Rectangle Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                           StrokeDashArray="4 3" RadiusX="8" RadiusY="8" />
                <TextBlock Text="Drop files here" Foreground="{DynamicResource AccentBrush}"
                           FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
